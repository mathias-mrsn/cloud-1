# Optional AWS credentials for Terraform and the local WordPress bootstrap.
# Docker Compose reads this file automatically for `make docker-up ENABLE_LOCAL_STACK=true`.
# In local mode, MySQL runs in Docker while WordPress can still use AWS creds below to fetch
# salts and admin credentials when PREFIX / WORDPRESS_ADMIN_SECRET_ARN are provided.
ENABLE_LOCAL_STACK=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-west-3
AWS_DEFAULT_REGION=eu-west-3
PREFIX=
WORDPRESS_ADMIN_SECRET_ARN=

MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=rootpassword

WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_HOST=db
WORDPRESS_DB_PORT=3306
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
WORDPRESS_SITE_TITLE=Cloud-1 Local
WORDPRESS_SITE_URL=http://localhost:8080
WORDPRESS_SITE_HOST=localhost:8080
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=adminpassword
WORDPRESS_ADMIN_EMAIL=admin@example.com
WORDPRESS_LOCALE=en_US
WORDPRESS_SHARED_ROOT=/var/www/wordpress
WORDPRESS_EFS_DIR=/var/www/wordpress

PMA_HOST=db
PMA_PORT=3306
PMA_ARBITRARY=0
PMA_ABSOLUTE_URI=http://localhost:8081/
